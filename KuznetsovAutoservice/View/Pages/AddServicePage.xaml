<Page x:Class="KuznetsovAutoservice.View.Pages.AddServicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KuznetsovAutoservice.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="380" d:DesignWidth="590"
      Title="AddServicePage" Background="AliceBlue">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="10" />
            <RowDefinition Height="50" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="70" />
        </Grid.ColumnDefinitions>

        <TextBlock Text="Название:" Grid.Row="1" Grid.Column="1" TextAlignment="Right" FontSize="20" Height="25"/>
        <TextBlock Text="Цена:" Grid.Row="3" Grid.Column="1" TextAlignment="Right" FontSize="20" Height="25"/>


        <TextBox Name="NameTb" Grid.Row="1" Grid.Column="3" FontSize="20" Height="25"/>
        <TextBox Name="PriceTb" Grid.Row="3" Grid.Column="3" FontSize="20" Height="25"/>


        <Button Name="AddBtn" Grid.Column="4" Grid.Row="5" Content="Добавить" Width="100" Height="40" Click="AddBtn_Click"/>
        <Button Name="MainBtn" Grid.Column="4" Grid.Row="6" Content="Выйти в меню" Width="100" VerticalAlignment="Top" Margin="0 10 0 0" Height="40" Click="MainBtn_Click"/>
    </Grid>
</Page>
