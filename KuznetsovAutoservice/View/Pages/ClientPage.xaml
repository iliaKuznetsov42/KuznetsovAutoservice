<Page x:Class="KuznetsovAutoservice.View.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KuznetsovAutoservice.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="380" d:DesignWidth="590"
      Title="ClientPage" Background="AliceBlue">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="30" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>

        <Button Name="BackBtn" Grid.Column="2" Grid.Row="1" Width="140" Height="50" VerticalAlignment="Bottom" Content="Назад" Click="BackBtn_Click"/>

        <ListView Name="ClientLv" Grid.Row="1" Grid.RowSpan="3" Margin="10 0 10 0" FontSize="16" SelectionChanged="ClientLv_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя" Width="80" DisplayMemberBinding="{Binding FirstName}"/>
                    <GridViewColumn Header="Фамилия" Width="80" DisplayMemberBinding="{Binding LastName}"/>
                    <GridViewColumn Header="Телефон" Width="100" DisplayMemberBinding="{Binding Phone}"/>
                    <GridViewColumn Header="Почта" Width="80" DisplayMemberBinding="{Binding Email}"/>
                    <GridViewColumn Header="Марка" Width="80" DisplayMemberBinding="{Binding Cars.Brand}"/>
                    <GridViewColumn Header="Модель" Width="80" DisplayMemberBinding="{Binding Cars.Model}"/>
                    <GridViewColumn Header="Гос Номер" Width="80" DisplayMemberBinding="{Binding Cars.LicensePlate}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
